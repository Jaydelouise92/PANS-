# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.

# EMAIL_USER: The Gmail address used to send emails (default: ourvoicemattersaus@gmail.com)
EMAIL_USER="ourvoicemattersaus@gmail.com"

# EMAIL_PASS: The password or app password for the email account.
# If using Gmail, this should be an "App Password".
EMAIL_PASS=""

# ADMIN_EMAIL: The email address where contact form submissions and feedback are sent.
ADMIN_EMAIL="admin@example.com"

# DASHBOARD_PASSWORD: The password required to access the /dashboard route.
DASHBOARD_PASSWORD="change-me-in-production"
